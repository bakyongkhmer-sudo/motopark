{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/",
      "destination": "/web_portal/index.html"
    },
    {
      "source": "/portal.js",
      "destination": "/web_portal/portal.js"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
